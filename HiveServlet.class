<%-- inspections.jsp --%>
<%@ page contentType="text/html;charset=UTF-8" import="java.util.*" %>
<%
  if (session.getAttribute("userId") == null) {
      response.sendRedirect("login.jsp");
      return;
  }
  List<Map<String,Object>> inspections = (List<Map<String,Object>>) request.getAttribute("inspections");
  List<Map<String,Object>> hives       = (List<Map<String,Object>>) request.getAttribute("hives");
%>
<!DOCTYPE html>
<html>
<head>
  <title>Inspections – Sunny Day Apiary</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <%@ include file="navbar.jsp" %>
  <main class="container">
    <h1>Hive Inspections</h1>

    <div style="display:flex; justify-content:flex-end; margin-bottom:12px;">
      <a href="export?type=inspections" class="btn-export">&#8595; Export CSV</a>
    </div>

    <table class="data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Hive</th>
          <th>Inspector</th>
          <th>Date</th>
          <th>Health (1–10)</th>
          <th>Queen Seen</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% if (inspections != null) { for (Map<String,Object> i : inspections) {
             int rating = i.get("health_rating") != null ? Integer.parseInt(i.get("health_rating").toString()) : 0;
             String healthClass = rating >= 8 ? "health-high" : (rating >= 5 ? "health-mid" : "health-low");
             String queenIcon   = "Yes".equals(i.get("queen_seen")) ? "&#10003; Yes" : "&#10007; No";
        %>
        <tr>
          <td><%= i.get("inspection_id")   %></td>
          <td><%= i.get("hive_name")       %></td>
          <td><%= i.get("inspector")       %></td>
          <td><%= i.get("inspection_date") %></td>
          <td><span class="health-badge <%= healthClass %>"><%= rating %></span></td>
          <td><%= queenIcon %></td>
          <td><%= i.get("notes")           %></td>
        </tr>
        <% } } %>
      </tbody>
    </table>

    <section class="form-section">
      <div class="form-section-header">
        <h2>Log New Inspection</h2>
        <button type="button" class="btn-toggle" onclick="toggleForm('inspectionForm', this)">+ Add New</button>
      </div>
      <div id="inspectionForm" class="form-body" style="display:none;">
        <form method="post" action="inspections">
          <div class="form-row">
            <label>Hive *
              <select name="hive_id" required>
                <% if (hives != null) { for (Map<String,Object> h : hives) { %>
                  <option value="<%= h.get("hive_id") %>"><%= h.get("hive_name") %></option>
                <% } } %>
              </select>
            </label>
            <label>Date *
              <input type="date" name="inspection_date" required>
            </label>
          </div>
          <div class="form-row">
            <label>Health Rating (1–10) *
              <input type="number" name="health_rating" min="1" max="10" required>
            </label>
            <label>Queen Seen?
              <select name="queen_seen">
                <option value="1">Yes</option>
                <option value="0">No</option>
              </select>
            </label>
          </div>
          <label>Notes
            <textarea name="notes" rows="3"></textarea>
          </label>
          <button type="submit" class="btn-primary">Save Inspection</button>
        </form>
      </div>
    </section>
  </main>
  <footer class="footer">Sunny Day Apiary Management System &copy; 2025</footer>

  <script>
    function toggleForm(id, btn) {
      var el = document.getElementById(id);
      if (el.style.display === 'none') {
        el.style.display = 'block';
        btn.innerHTML = '&#8722; Cancel';
      } else {
        el.style.display = 'none';
        btn.innerHTML = '+ Add New';
      }
    }
  </script>
</body>
</html>
