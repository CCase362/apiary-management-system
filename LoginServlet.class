<%-- orders.jsp --%>
<%@ page contentType="text/html;charset=UTF-8" import="java.util.*" %>
<%
  if (session.getAttribute("userId") == null) {
      response.sendRedirect("login.jsp");
      return;
  }
  String role = (String) session.getAttribute("role");
  List<Map<String,Object>> orders    = (List<Map<String,Object>>) request.getAttribute("orders");
  List<Map<String,Object>> customers = (List<Map<String,Object>>) request.getAttribute("customers");
  String error = (String) request.getAttribute("error");
%>
<!DOCTYPE html>
<html>
<head>
  <title>Orders – Sunny Day Apiary</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <%@ include file="navbar.jsp" %>
  <main class="container">
    <h1>Customer Orders</h1>

    <div style="display:flex; justify-content:flex-end; margin-bottom:12px;">
      <a href="export?type=orders" class="btn-export">&#8595; Export CSV</a>
    </div>

    <% if (error != null) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <table class="data-table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Date</th>
          <th>Total ($)</th>
          <th>Status</th>
          <% if ("admin".equals(role)) { %><th>Update</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% if (orders != null && !orders.isEmpty()) {
             for (Map<String,Object> o : orders) { %>
        <tr>
          <td><%= o.get("order_id")      %></td>
          <td><%= o.get("customer_name") %></td>
          <td><%= o.get("order_date")    %></td>
          <td>$<%= o.get("total_amount") %></td>
          <td><span class="badge badge-<%= o.get("order_status").toString().toLowerCase() %>">
            <%= o.get("order_status") %>
          </span></td>
          <% if ("admin".equals(role)) { %>
          <td>
            <form method="post" action="orders" style="display:inline;">
              <input type="hidden" name="action"    value="update">
              <input type="hidden" name="order_id"  value="<%= o.get("order_id") %>">
              <select name="order_status" onchange="this.form.submit()">
                <option <%= "Pending".equals(o.get("order_status"))   ? "selected" : "" %>>Pending</option>
                <option <%= "Shipped".equals(o.get("order_status"))   ? "selected" : "" %>>Shipped</option>
                <option <%= "Delivered".equals(o.get("order_status")) ? "selected" : "" %>>Delivered</option>
                <option <%= "Cancelled".equals(o.get("order_status")) ? "selected" : "" %>>Cancelled</option>
              </select>
            </form>
          </td>
          <% } %>
        </tr>
        <% } } else { %>
        <tr><td colspan="6" style="text-align:center; color:#888; padding:20px;">No orders yet.</td></tr>
        <% } %>
      </tbody>
    </table>

    <% if ("admin".equals(role)) { %>
    <section class="form-section">
      <div class="form-section-header">
        <h2>Add New Order</h2>
        <button type="button" class="btn-toggle" onclick="toggleForm('orderForm', this)">+ Add New</button>
      </div>
      <div id="orderForm" class="form-body" style="display:none;">
        <form method="post" action="orders">
          <input type="hidden" name="action" value="add">
          <div class="form-row">
            <label>Customer *
              <select name="customer_id" required>
                <option value="">-- Select Customer --</option>
                <% if (customers != null) { for (Map<String,Object> c : customers) { %>
                  <option value="<%= c.get("customer_id") %>"><%= c.get("customer_name") %></option>
                <% } } %>
              </select>
            </label>
            <label>Order Date *
              <input type="date" name="order_date" required>
            </label>
          </div>
          <div class="form-row">
            <label>Total Amount ($)
              <input type="number" name="total_amount" step="0.01" min="0">
            </label>
            <label>Status
              <select name="order_status">
                <option value="Pending">Pending</option>
                <option value="Shipped">Shipped</option>
                <option value="Delivered">Delivered</option>
                <option value="Cancelled">Cancelled</option>
              </select>
            </label>
          </div>
          <button type="submit" class="btn-primary">Create Order</button>
        </form>
      </div>
    </section>
    <% } %>
  </main>
  <footer class="footer">Sunny Day Apiary Management System &copy; 2025</footer>

  <script>
    function toggleForm(id, btn) {
      var el = document.getElementById(id);
      if (el.style.display === 'none') {
        el.style.display = 'block';
        btn.innerHTML = '&#8722; Cancel';
      } else {
        el.style.display = 'none';
        btn.innerHTML = '+ Add New';
      }
    }
  </script>
</body>
</html>
