<%-- products.jsp --%>
<%@ page contentType="text/html;charset=UTF-8" import="java.util.*" %>
<%
  if (session.getAttribute("userId") == null) {
      response.sendRedirect("login.jsp");
      return;
  }
  String role = (String) session.getAttribute("role");
  List<Map<String,Object>> products = (List<Map<String,Object>>) request.getAttribute("products");
  String error = (String) request.getAttribute("error");
%>
<!DOCTYPE html>
<html>
<head>
  <title>Products – Sunny Day Apiary</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <%@ include file="navbar.jsp" %>
  <main class="container">
    <h1>Product Inventory</h1>

    <% if (error != null) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <table class="data-table">
      <thead>
        <tr><th>ID</th><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Honey Type</th><% if ("admin".equals(role)) { %><th>Delete</th><% } %></tr>
      </thead>
      <tbody>
        <% if (products != null) { for (Map<String,Object> p : products) { %>
        <tr>
          <td><%= p.get("product_id") %></td>
          <td><%= p.get("product_name") %></td>
          <td><%= p.get("category") %></td>
          <td>$<%= p.get("price") %></td>
          <td><%= p.get("stock_quantity") %></td>
          <td><%= p.get("honey_type") != null ? p.get("honey_type") : "N/A" %></td>
          <% if ("admin".equals(role)) { %>
          <td>
            <form method="post" action="products" onsubmit="return confirm('Delete <%= p.get("product_name") %>?');">
              <input type="hidden" name="action" value="delete">
              <input type="hidden" name="product_id" value="<%= p.get("product_id") %>">
              <button type="submit" class="btn-delete">Delete</button>
            </form>
          </td>
          <% } %>
        </tr>
        <% } } %>
      </tbody>
    </table>

    <% if ("admin".equals(role)) { %>
    <section class="form-section">
      <div class="form-section-header">
        <h2>Add New Product</h2>
        <button type="button" class="btn-toggle" onclick="toggleForm('productForm', this)">+ Add New</button>
      </div>
      <div id="productForm" class="form-body" style="display:none;">
        <form method="post" action="products">
          <div class="form-row">
            <label>Product Name *<input type="text" name="product_name" required></label>
            <label>Category<input type="text" name="category"></label>
          </div>
          <div class="form-row">
            <label>Price *<input type="number" step="0.01" min="0.01" name="price" required></label>
            <label>Stock Quantity *<input type="number" min="0" name="stock_quantity" required></label>
            <label>Batch ID<input type="number" min="1" name="batch_id"></label>
          </div>
          <button type="submit" class="btn-primary">Add Product</button>
        </form>
      </div>
    </section>
    <% } %>
  </main>
  <footer class="footer">Sunny Day Apiary Management System &copy; 2025</footer>
  <script>
    function toggleForm(id, btn) {
      var el = document.getElementById(id);
      if (el.style.display === 'none') { el.style.display = 'block'; btn.innerHTML = '&#8722; Cancel'; }
      else { el.style.display = 'none'; btn.innerHTML = '+ Add New'; }
    }
  </script>
</body>
</html>
